# Single source of truth for this SaaS deployment.
# Copy to ./saas.env, adjust values, then run: bash scripts/sync-config.sh

TOOL_PROJECT_ID=your-tool-project-id
MANAGED_PROJECT_ID=your-managed-project-id
ORGANIZATION_ID=
REGION=asia-northeast1
BQ_DATASET_ID=iam_access_mgmt
CLOUD_RUN_SERVICE_NAME=iam-access-executor

# Artifact Registry (iam-access-repo is created automatically by Terraform)
CLOUD_RUN_IMAGE=asia-northeast1-docker.pkg.dev/your-tool-project-id/iam-access-repo/iam-access-executor:latest

WORKSPACE_CUSTOMER_ID=my_customer

# --- Scheduler Cron Definitions ---
REVOKE_EXPIRED_PERMISSIONS_SCHEDULE="0 1 * * *"
IAM_BINDINGS_HISTORY_UPDATE_SCHEDULE="0 2 * * *"
RESOURCE_COLLECTION_SCHEDULE="0 3 * * *"
GROUP_COLLECTION_SCHEDULE="30 3 * * *"
IAM_POLICY_COLLECTION_SCHEDULE="15 3 * * *"
RECONCILIATION_SCHEDULE="0 4 * * *"

SCHEDULER_TIME_ZONE=Asia/Tokyo
BQ_LOCATION=asia-northeast1

TFSTATE_BUCKET=your-tool-project-id-tfstate
TFSTATE_PREFIX=cloud-access-manager
TFSTATE_LOCATION=asia-northeast1
GEMINI_API_KEY=

# --- Security & Triggers ---
# GoogleフォームのGASトリガーを仕掛けたユーザーのメールアドレス (必須)
GAS_TRIGGER_OWNER_EMAIL="your-google-account@example.com"

# --- Monitoring Alerts (Optional) ---
# エラー時や緊急アクセス(Break-glass)検知時の通知先
ALERT_NOTIFICATION_EMAIL=""
ALERT_NOTIFICATION_WEBHOOK_URL=""

# --- VPC Service Controls (Optional) ---
enable_vpc_sc=false
access_policy_name=""
