# Copy to ./saas.env and adjust values.

TOOL_PROJECT_ID=your-tool-project-id
MANAGED_PROJECT_ID=your-managed-project-id
ORGANIZATION_ID=
REGION=asia-northeast1
BQ_DATASET_ID=iam_access_mgmt
CLOUD_RUN_SERVICE_NAME=iam-access-executor
CLOUD_RUN_IMAGE=asia-northeast1-docker.pkg.dev/your-tool-project-id/your-repo/iam-access-executor:latest
WEBHOOK_SECRET_NAME=iam-access-webhook-token
WORKSPACE_CUSTOMER_ID=my_customer
RESOURCE_COLLECTION_SCHEDULE="0 3 * * *"
GROUP_COLLECTION_SCHEDULE="30 3 * * *"
SCHEDULER_TIME_ZONE=Asia/Tokyo
BQ_LOCATION=asia-northeast1
TFSTATE_BUCKET=your-tool-project-id-tfstate
TFSTATE_PREFIX=cloud-access-manager
TFSTATE_LOCATION=asia-northeast1
GEMINI_API_KEY=

# Monitoring Alerts (Optional)
ALERT_NOTIFICATION_EMAIL=
ALERT_NOTIFICATION_WEBHOOK_URL=
